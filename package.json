{
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "crypto": "^1.0.1",
    "d3": "^7.9.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "express": "^5.2.1",
    "http-errors": "^2.0.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemon": "^3.1.14",
    "pg": "^8.21.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "migration:dev": "dotenv -e .env -- npx prisma migrate dev",
    "migration:reset": "dotenv -e .env -- npx prisma migrate reset",
